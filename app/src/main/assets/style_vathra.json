{
  "version": 8,
  "name": "OpenTopo Basemap",
  "sources": {
    "vathra": {
      "type": "vector",
      "url": "https://vathra-tiles.vathra.workers.dev/greece.json",
      "maxzoom": 13,
      "attribution": "&copy; <a href='https://openstreetmap.org'>OpenStreetMap</a>"
    },
    "contours": {
      "type": "vector",
      "url": "https://vathra-tiles.vathra.workers.dev/contours.json",
      "maxzoom": 14,
      "attribution": ""
    }
  },
  "glyphs": "https://cdn.protomaps.com/fonts/pbf/{fontstack}/{range}.pbf",
  "layers": [
    {"id": "background", "type": "background", "paint": {"background-color": "#f0ede9"}},
    {"id": "earth", "type": "fill", "source": "vathra", "source-layer": "earth", "paint": {"fill-color": "#f0ede9"}},
    {"id": "water", "type": "fill", "source": "vathra", "source-layer": "water", "paint": {"fill-color": "#b4d4e1"}},

    {"id": "landcover-grass", "type": "fill", "source": "vathra", "source-layer": "landcover",
      "filter": ["==", "pmap:kind", "grass"],
      "paint": {"fill-color": "#d8e8c8", "fill-opacity": 0.6}},
    {"id": "landcover-forest", "type": "fill", "source": "vathra", "source-layer": "landcover",
      "filter": ["==", "pmap:kind", "forest"],
      "paint": {"fill-color": "#c5dfad", "fill-opacity": 0.5}},

    {"id": "landuse-park", "type": "fill", "source": "vathra", "source-layer": "landuse",
      "filter": ["in", "kind", "park", "garden", "nature_reserve"],
      "paint": {"fill-color": "#d0e8c0", "fill-opacity": 0.5}},
    {"id": "landuse-residential", "type": "fill", "source": "vathra", "source-layer": "landuse",
      "filter": ["==", "kind", "residential"],
      "paint": {"fill-color": "#e8e0d8", "fill-opacity": 0.4}},
    {"id": "landuse-industrial", "type": "fill", "source": "vathra", "source-layer": "landuse",
      "filter": ["in", "kind", "industrial", "commercial"],
      "paint": {"fill-color": "#e0dbd4", "fill-opacity": 0.3}},

    {"id": "boundaries", "type": "line", "source": "vathra", "source-layer": "boundaries",
      "paint": {"line-color": "#bab0a8", "line-width": 1, "line-dasharray": [3, 2]}},

    {"id": "roads-path", "type": "line", "source": "vathra", "source-layer": "roads",
      "filter": ["in", "kind", "path"],
      "minzoom": 12,
      "paint": {"line-color": "#d4c8b8", "line-width": 0.8, "line-dasharray": [4, 2]}},
    {"id": "roads-minor", "type": "line", "source": "vathra", "source-layer": "roads",
      "filter": ["in", "kind", "minor_road", "other"],
      "minzoom": 10,
      "paint": {"line-color": "#ffffff", "line-width": {"stops": [[10, 0.5], [14, 3], [18, 8]]}}},
    {"id": "roads-medium", "type": "line", "source": "vathra", "source-layer": "roads",
      "filter": ["in", "kind", "medium_road"],
      "minzoom": 8,
      "paint": {"line-color": "#ffffff", "line-width": {"stops": [[8, 0.5], [14, 5], [18, 12]]}}},
    {"id": "roads-major-casing", "type": "line", "source": "vathra", "source-layer": "roads",
      "filter": ["in", "kind", "major_road", "highway"],
      "minzoom": 5,
      "paint": {"line-color": "#d4c4a8", "line-width": {"stops": [[5, 1], [14, 9], [18, 16]]}}},
    {"id": "roads-major", "type": "line", "source": "vathra", "source-layer": "roads",
      "filter": ["in", "kind", "major_road", "highway"],
      "minzoom": 5,
      "paint": {"line-color": "#faf5e8", "line-width": {"stops": [[5, 0.5], [14, 7], [18, 14]]}}},

    {"id": "buildings", "type": "fill", "source": "vathra", "source-layer": "buildings",
      "minzoom": 12,
      "paint": {"fill-color": "#d9d0c8", "fill-opacity": 0.7}},
    {"id": "buildings-outline", "type": "line", "source": "vathra", "source-layer": "buildings",
      "minzoom": 14,
      "paint": {"line-color": "#c0b8b0", "line-width": 0.5}},

    {"id": "contours-lines", "type": "line", "source": "contours", "source-layer": "contours",
      "minzoom": 11,
      "paint": {"line-color": "#c4a882", "line-width": 0.6, "line-opacity": 0.5}},
    {"id": "contours-labels", "type": "symbol", "source": "contours", "source-layer": "contours",
      "minzoom": 13,
      "filter": ["==", ["%", ["get", "elevation"], 50], 0],
      "layout": {"text-field": ["concat", ["to-string", ["get", "elevation"]], "m"], "text-font": ["Noto Sans Regular"], "text-size": 9, "symbol-placement": "line"},
      "paint": {"text-color": "#a08060", "text-halo-color": "#ffffff", "text-halo-width": 1}},

    {"id": "place-labels-village", "type": "symbol", "source": "vathra", "source-layer": "places",
      "filter": ["in", "kind", "village", "hamlet", "suburb", "neighbourhood"],
      "minzoom": 10,
      "layout": {"text-field": ["coalesce", ["get", "name:el"], ["get", "name"]], "text-font": ["Noto Sans Regular"], "text-size": 12, "text-max-width": 8},
      "paint": {"text-color": "#6b6560", "text-halo-color": "#ffffff", "text-halo-width": 1.5}},
    {"id": "place-labels-town", "type": "symbol", "source": "vathra", "source-layer": "places",
      "filter": ["in", "kind", "town", "borough"],
      "minzoom": 7,
      "layout": {"text-field": ["coalesce", ["get", "name:el"], ["get", "name"]], "text-font": ["Noto Sans Medium"], "text-size": {"stops": [[7, 11], [13, 16]]}, "text-max-width": 8},
      "paint": {"text-color": "#4a4540", "text-halo-color": "#ffffff", "text-halo-width": 1.5}},
    {"id": "place-labels-city", "type": "symbol", "source": "vathra", "source-layer": "places",
      "filter": ["in", "kind", "city", "state"],
      "minzoom": 4,
      "layout": {"text-field": ["coalesce", ["get", "name:el"], ["get", "name"]], "text-font": ["Noto Sans Bold"], "text-size": {"stops": [[4, 12], [10, 22]]}, "text-max-width": 10},
      "paint": {"text-color": "#333030", "text-halo-color": "#ffffff", "text-halo-width": 2}},
    {"id": "road-labels", "type": "symbol", "source": "vathra", "source-layer": "roads",
      "filter": ["in", "kind", "major_road", "highway", "medium_road"],
      "minzoom": 12,
      "layout": {"text-field": ["coalesce", ["get", "name:el"], ["get", "name"]], "text-font": ["Noto Sans Regular"], "text-size": 10, "symbol-placement": "line", "text-max-angle": 30},
      "paint": {"text-color": "#6b6560", "text-halo-color": "#ffffff", "text-halo-width": 1}}
  ]
}
